# shellcheck shell=bash
# shellcheck disable=SC2034  # Vars consumed by Kamal externally.
# Pulls credentials from the sibling infra repo's SOPS files.
# Kamal parses this file with dotenv (NOT bash): plain assignment + $(...) work,
# but bash default-expansion ${VAR:-default} does not — keep this a literal.
INFRA=../../infra
APP=cube-worlds-bot

# GHCR push/pull password (shared across all apps).
KAMAL_REGISTRY_PASSWORD=$(sops -d --extract '["docker_registry_password"]' "$INFRA/secrets/shared.enc.yaml")

# Per-app secrets (SOPS keys chosen to match .sops.yaml encrypted_regex).
MONGO=$(sops -d --extract '["mongo_uri"]' "$INFRA/secrets/apps/$APP.enc.yaml")
BOT_TOKEN=$(sops -d --extract '["bot_token"]' "$INFRA/secrets/apps/$APP.enc.yaml")
# Webhook is token-in-path; derive it from the token so there's one source of truth.
BOT_WEBHOOK=https://cubeworlds.club/$(sops -d --extract '["bot_token"]' "$INFRA/secrets/apps/$APP.enc.yaml")
MNEMONICS=$(sops -d --extract '["mnemonics_secret"]' "$INFRA/secrets/apps/$APP.enc.yaml")
PINATA_API_KEY=$(sops -d --extract '["pinata_api_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
PINATA_API_SECRET=$(sops -d --extract '["pinata_api_secret"]' "$INFRA/secrets/apps/$APP.enc.yaml")
PINATA_GATEWAY_KEY=$(sops -d --extract '["pinata_gateway_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
TONCENTER_API_KEY=$(sops -d --extract '["toncenter_api_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
STABILITY_API_KEY=$(sops -d --extract '["stability_api_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
OPENAI_API_KEY=$(sops -d --extract '["openai_api_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
TELEMETREE_API_KEY=$(sops -d --extract '["telemetree_api_key"]' "$INFRA/secrets/apps/$APP.enc.yaml")
# SOPS key is tappads_url_secret (ends _secret so encrypted_regex encrypts it); env var is TAPPADS_SECRET_URL.
TAPPADS_SECRET_URL=$(sops -d --extract '["tappads_url_secret"]' "$INFRA/secrets/apps/$APP.enc.yaml")
